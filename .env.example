# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Formato asyncpg. Ejemplos:
#   Local:           postgresql+asyncpg://usuario:password@localhost:5432/dbname
#   Render Internal: postgresql+asyncpg://usuario:password@dpg-xxx.oregon-postgres.render.com/dbname
#   Render External: postgresql+asyncpg://usuario:password@dpg-xxx.render.com/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/dbname

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
# Clave enviada en el header X-API-Key para proteger endpoints internos.
# El endpoint público del widget (/webhook/{slug}/chat) no requiere API key.
API_SECRET_KEY=cambia-esta-clave-en-produccion

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Formato: URLs separadas por coma, sin espacios, sin corchetes.
# Desarrollo:  CORS_ORIGINS=*
# Producción:  CORS_ORIGINS=https://www.brucellariabienesraices.com.ar,https://brucellariabienesraices.com.ar
CORS_ORIGINS=*

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── PIPELINE ─────────────────────────────────────────────────────────────────
MAX_ITEMS_PER_RESPONSE=5
CONTEXT_WINDOW_MESSAGES=10
