# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Formato asyncpg: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/inmobot_premium

# ─── ANTHROPIC ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Modelos utilizados por el pipeline
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# ─── SEGURIDAD ───────────────────────────────────────────────────────────────
# Clave secreta para proteger los endpoints (header X-API-Key)
API_SECRET_KEY=cambia-esta-clave-en-produccion

# ─── CORS ────────────────────────────────────────────────────────────────────
# Lista separada por comas. Usar * solo en desarrollo.
CORS_ORIGINS=*

# ─── LOGGING ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── PIPELINE ────────────────────────────────────────────────────────────────
# Máximo de items devueltos por respuesta conversacional
MAX_ITEMS_PER_RESPONSE=5
# Cantidad de mensajes recientes a incluir en el contexto
CONTEXT_WINDOW_MESSAGES=10
