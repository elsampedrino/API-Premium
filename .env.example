# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Formato asyncpg: postgresql+asyncpg://user:password@host:port/dbname
# Usar External URL de Render cuando la API corre en local.
DATABASE_URL=postgresql+asyncpg://usuario:password@host:5432/dbname

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6

# ─── SEGURIDAD ────────────────────────────────────────────────────────────────
# Clave enviada en el header X-API-Key para proteger los endpoints.
API_SECRET_KEY=cambia-esta-clave-en-produccion

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Formato JSON. En desarrollo usar ["*"]. En producción listar orígenes exactos.
# Ejemplo producción: ["https://tudominio.com","https://widget.tudominio.com"]
CORS_ORIGINS=["*"]

# ─── LOGGING ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── PIPELINE ─────────────────────────────────────────────────────────────────
MAX_ITEMS_PER_RESPONSE=5
CONTEXT_WINDOW_MESSAGES=10